{
  "name": "@venipa/xosms",
  "version": "0.7.0",
  "main": "index.js",
  "types": "index.d.ts",
  "napi": {
    "name": "xosms",
    "triples": {
      "additional": [
        "aarch64-apple-darwin",
        "aarch64-unknown-linux-gnu",
        "aarch64-pc-windows-msvc",
        "universal-apple-darwin"
      ]
    },
    "package": {
      "name": "@venipa/xosms"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public",
    "tag": "latest",
    "provenance": false
  },
  "license": "Apache-2.0",
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "ava": "^6.0.1"
  },
  "ava": {
    "timeout": "3m"
  },
  "engines": {
    "node": ">= 10"
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release --js-package-name @venipa/xosms",
    "build:debug": "napi build --platform",
    "prepublishOnly": "napi prepublish -t npm",
    "test": "ava",
    "universal": "napi universal",
    "version": "napi version"
  },
  "packageManager": "yarn@4.1.0",
  "repository": "https://github.com/venipa/xosms.git",
  "description": "Cross platform media service module. Hooks into each operating system's native media service and provides a simple API to access and use it.",
  "keywords": [
    "electron",
    "media",
    "service",
    "media service",
    "cross",
    "platform",
    "cross platform"
  ]
}
